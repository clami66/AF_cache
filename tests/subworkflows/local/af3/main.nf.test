nextflow_workflow {

    name "Test Workflow AF3"
    script "subworkflows/local/af3/main.nf"
    config "tests/subworkflows/local/af3/nextflow.config"
    workflow "AF3"

    test("Should run without failures") {

        when {
            params {
                // define parameters here. Example:
                outdir = "tests/results_AF3"
            }
            workflow {
                """
                // define inputs of the workflow here
                // alignments_path
                // fasta_links
                // split_fasta_path
                // pair_list
                input[0] = "${projectDir}/test_data/alignments"
                input[1] = Channel.fromPath("${projectDir}/test_data/fasta/*.fasta")
                input[2] = "${projectDir}/test_data/split_fasta"
                input[3] = "${projectDir}/test_data/inputs/pair_list.txt"
                """
            }
        }

        then {
            assert workflow.success
        }

    }

}
