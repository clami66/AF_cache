nextflow_workflow {

    name "Test Workflow AF2"
    script "subworkflows/local/af2/main.nf"
    config "tests/subworkflows/local/af2/nextflow.config"
    workflow "AF2"

    test("Should run without failures") {

        when {
            params {
                outdir = "tests/results_AF2"
            }
            workflow {
                """
                input[0] = "${projectDir}/test_data/alignments"
                input[1] = "${projectDir}/test_data/inputs/fasta/"
                input[2] = "${projectDir}/test_data/inputs/pair_list.txt"
                """
            }
        }

        then {
            assert workflow.success
        }

    }

}
