nextflow_process {

    name "Test Process format_jobs"
    script "modules/local/af2/main.nf"
    config "tests/modules/local/af2/nextflow.config"
    process "format_jobs"

    test("Should run without failures") {

        when {
            params {

            }
            process {
                """
                input[0] = "${projectDir}/test_data/inputs/fasta"
                input[1] = "${projectDir}/test_data/pickle_cache"
                input[2] = "${projectDir}/test_data/inputs/pair_list.txt"
                input[3] = "${projectDir}/test_data/.foo"
                input[4] = "${projectDir}/database/pdb_mmcif/mmcif_files"
                input[5] = "${projectDir}/database/pdb_mmcif/obsolete.dat"
                input[6] = "${projectDir}/database/pdb_seqres/pdb_seqres.txt"
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }

    }

}
