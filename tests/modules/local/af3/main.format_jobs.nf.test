nextflow_process {

    name "Test Process format_jobs"
    script "modules/local/af3/main.nf"
    config "tests/modules/local/af3/nextflow.config"
    process "format_jobs"

    test("Should run without failures") {

        when {
            params {

            }
            process {
                """
                input[0] = "${projectDir}/test_data/split_fasta"
                input[1] = "${projectDir}/test_data/json_cache"
                input[2] = "${projectDir}/test_data/inputs/pair_list.txt"
                """
            }
        }

        then {
            assert process.success
            //assert snapshot(process.out).match()
        }

    }

}
