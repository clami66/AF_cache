executor {
    name = "local"
    queueSize = 32
    cpus = 16
}

executor {
    name = "slurm"
    queueSize = 100
}

env {
    PYTHONPATH = "${AF_CACHE}:${PYTHONPATH}"
}

params {
    // JOB PARAMETERS
    no_file = "$AF_CACHE/pipeline/common/.NO_FILE"
    pair_list  = no_file
    af_cache_dir = "$AF_CACHE" // path the the git repo cloning directory
    output_dir = 'outputs/'
    af3 = false
    test = false

    // SCHEDULER PARAMETERS
    // MMseqs2 job parameters
    mmseqs_executor = 'slurm'
    mmseqs_executor_flags = '--account berzelius-2026-12 --gpus 1 --time 2:00:00 --reservation=devel'
    n_gpu = 1 // set to 0 to run CPU version of MMseqs2
    max_cpus = 64
    n_cpus_per_gpu = 8

    // AF job parameters
    af_executor = 'slurm'
    af_executor_flags = '--account berzelius-2026-12 --gpus 1 --time 12:00:00'

    // smaller jobs (eature parsing, etc.). Usually on local CPUs
    other_executor = 'local'
    other_executor_flags = ''

    // TOOL PARAMETERS
    // mmseqs2 parameters
    mmseqs_db = "$AF_CACHE/database/"                             // path to colabfold dbs. If installation was done as on README, no need to change anything
    mmseqs_bin = "$AF_CACHE/mmseqs/bin/mmseqs"                    // path to mmseqs binary. Should be here if installation instructions were followed
    use_env = true                                                // whether the environmental sequences DB should also be searched with MMseqs2

    // af2 parameters
    af2_flagfile = "$AF_CACHE/flags/af2.flag"    // flagfile with default AF2.3 inference parameters
    af2_data_dir = '/proj/beyondfold/apps/alphafold_data'
    skip_templates = false
    template_mmcif_dir = "/proj/beyondfold/apps/alphafold_data/pdb_mmcif/mmcif_files"
    obsolete_pdbs_path = "/proj/beyondfold/apps/alphafold_data/pdb_mmcif/obsolete.dat"
    pdb_seqres_database_path = "/proj/beyondfold/apps/alphafold_data/pdb_seqres/pdb_seqres.txt"

    // af3 parameters
    af3_flagfile = "$AF_CACHE/flags/af3/af3.flag"
}

// CONTAINERS/CONDA CONFIG
// if you want to use Docker instead of apptainer: set apptainer -> enabled = false, docker -> enabled = true
// if you want to change the path where the apptainer .sif image is cached the first time it's pulled set the ennvar `NXF_APPTAINER_CACHEDIR`
apptainer {
    enabled = false
    runOptions = "--nv"
}

docker {
    enabled = false
    runOptions = "--gpus all"
}

conda {
    enabled = true
    useMamba = true
    cacheDir = "$AF_CACHE/conda"
    createTimeout = '1 h'
}

process {
    // execution settings
    withName:'mmseqs_align' {
        executor = 'slurm'
        clusterOptions = '--account berzelius-2026-12 --gpus 1 --time 2:00:00 --reservation=devel'
    }

    withName:'run_af2_jobs|run_af3_jobs' {
        executor = 'slurm'
        clusterOptions = '--account berzelius-2026-12 --gpus 1 --time 12:00:00'
    }

    withName:'ln_fasta|split_fasta|collect_pickles|collect_jsons' {
        executor = 'local'
    }

    withName:'convert_alignments_af2|convert_alignments_af3|parse_features_af2|parse_features_af3|format_jobs_af2|format_jobs_af3' {
        executor = 'local'
    }

    // AF2 container/conda settings
    withName:'split_fasta|mmseqs_align|parse_features_af2|format_jobs_af2|format_jobs_af3|run_af2_jobs|convert_alignments_af2|convert_alignments_af3' {
        container = 'docker://clami66/af_cache:test'
        conda = '/proj/beyondfold/apps/.conda/envs/AF_cache2'
    }

    // AF3 container/conda settings
    withName:"run_af3_jobs|parse_features_af3" {
        container = 'docker://alphafold3' // need to provide own AF3 docker image
        conda = '/proj/beyondfold/apps/.conda/envs/AF3_cache'
    }
}
