executor{
    name = "slurm"
    queueSize = 100
}

executor{
    name = "local"
    cpus = 8
}

params {
    # job parameters
    file_list = ''
    af_cache_dir = './'

    # mmseqs2 parameters
    mmseqs_db = 'database/'
    mmseqs_bin = 'mmseqs/bin/mmseqs'
    use_env = true

    # af2 parameters
    conda_env = 'AF_cache'
    af_flagfile = 'flags/multimer.flag'
    db_flagfile = 'flags/databases.flag'
    
    # slurm and resources parameters
    n_gpu = 1
    max_cpus = 64
    params.test = false
    executor = 'slurm'
    params.proj_id = ''

    # af3 parameters
    af3_conda_env = ''
    af3_bin_dir = './'
    af3_dir = ''
    af3_flagfile = 'flags/af3/multimer.flag'
    af3_db_flagfile = 'flags/af3/databases.flag'
    af3_parse_flagfile = 'flags/af3/parse_features.flag'
}
