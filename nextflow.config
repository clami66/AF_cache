executor{
    name = "slurm"
    queueSize = 100
}

executor{
    name = "local"
    cpus = 8
}

params {
    // job parameters
    file_list  = ''
    af_cache_dir = '$AF_CACHE'

    // scheduler and resources parameters
    n_gpu = 1
    max_cpus = 64
    test = false
    executor = 'slurm'
    proj_id = 'berzelius-2026-12'

    // mmseqs2 parameters
    mmseqs_db = '$AF_CACHE/database/'
    mmseqs_bin = '$AF_CACHE/mmseqs/bin/mmseqs'
    use_env = true

    // af2 parameters
    conda_env = 'AF_cache'
    af_flagfile = '$AF_CACHE/flags/multimer.flag'
    db_flagfile = '$AF_CACHE/flags/databases.flag'

    // af3 parameters
    af3_conda_env = ''
    af3_bin_dir = ''
    af3_dir = ''
    af3_flagfile = '$AF_CACHE/flags/af3/multimer.flag'
    af3_db_flagfile = '$AF_CACHE/flags/af3/databases.flag'
    af3_parse_flagfile = '$AF_CACHE/flags/af3/parse_features.flag'
}
