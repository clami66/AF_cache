manifest {
    mainScript = 'AF_cache.nf'
}

executor {
    name = "local"
    queueSize = 32
    cpus = 16
}

executor {
    name = "slurm"
    queueSize = 100
}

env {
    PYTHONPATH = "${projectDir}:${PYTHONPATH}"
}

// JOB PARAMETERS
params {
    pair_list  = []
    af_cache_dir = "${projectDir}" // path the the git repo cloning directory
    output_dir = 'outputs/'
    af3 = false
    test = false

    // MMseqs2 job parameters
    mmseqs_n_gpu = 1
    mmseqs_max_cpus = 8
    mmseqs_db = "${projectDir}/database/"           // path to colabfold dbs. If installation was done as on README, no need to change anything
    mmseqs_bin = 'mmseqs'
    mmseqs_use_env = true                       // whether the environmental sequences DB should also be searched with MMseqs2

    // general AF parameters
    af_n_gpu = 1
    include_homomers = false
    skip_templates = true

    // AF2 parameters
    af2_flagfile = "${projectDir}/flags/af2.flag"    // flagfile with default AF2.3 inference parameters
    af2_data_dir = "${projectDir}/alphafold_data"

    template_mmcif_dir = "${projectDir}/database/pdb_mmcif/mmcif_files"
    obsolete_pdbs_path = "${projectDir}/database/pdb_mmcif/obsolete.dat"
    pdb_seqres_database_path = "${projectDir}/database/pdb_seqres/pdb_seqres.txt"

    // AF3 parameters
    af3_flagfile = "${projectDir}/flags/af3.flag"
    af3_model_dir = "/path/to/af3/parameters"
    af3_n_prediction_seeds = 1
}

// CONTAINERS/CONDA CONFIG
profiles {
    standard {
        docker.enabled = true
        docker.runOptions = "--gpus all"
    }

    apptainer {
        apptainer.enabled = true
        apptainer.runOptions = "--nv"
    }

    conda {
        conda.enabled = true
        conda.useMamba = false
        conda.cacheDir = "${projectDir}/conda"
        conda.createTimeout = '1 h'
    }
}

// execution settings
process {
    withName:'mmseqs_align' {
        executor = 'slurm'
        clusterOptions = "--account xxx-yyy-zzz --gpus $params.mmseqs_n_gpu --time 12:00:00"
    }

    withName:'run_af2_jobs|run_af3_jobs' {
        executor = 'slurm'
        clusterOptions = "--account xxx-yyy-zzz --gpus $params.af_n_gpu --time 12:00:00"
    }

    withName:'merge_fastas|split_fasta|collect_pickles|collect_jsons' {
        executor = 'local'
    }

    withName:'convert_alignments|parse_features_af2|parse_features_af3|format_jobs|setup_mmseqs2_dbs|get_params' {
        executor = 'local'
    }

    // AF2 container/conda settings
    withName:'merge_fastas|mmseqs_align|parse_features_af2|format_jobs|run_af2_jobs|convert_alignments|setup_mmseqs2_dbs|get_params' {
        container = 'docker://clami66/af_cache:test'
        conda = 'environments/af2.yaml'
    }

    // AF3 container/conda settings
    withName:"run_af3_jobs|parse_features_af3" {
        container = 'docker://kosinskilab/alphafold3'           // maintained by Kosinski lab
        conda = 'environments/af3.yaml'
    }
}
